# Copy this file to .env and fill in your real key. Never commit .env itself.
GOOGLE_API_KEY=your_gemini_api_key_here
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# Which Gemini model powers the reasoning/reporting agents.
# Confirmed available via the AI Studio model picker for this account
# as of June 2026 - verify this is still accurate before relying on it,
# since the Flash lineup moves fast.
SENTINEL_MODEL=gemini-3.5-flash
